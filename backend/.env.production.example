# =============================================
# UniCom CX – Backend Production Environment
# =============================================

# البيئة
NODE_ENV=production
PORT=3000

# قاعدة البيانات (Supabase PostgreSQL)
# استبدل [YOUR-PASSWORD] و [YOUR-PROJECT-ID] بقيم Supabase الخاصة بك
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres?schema=public

# Redis (يمكنك استخدام Upstash Redis مجاني)
# استبدل [USER] و [PASSWORD] و [HOST] و [PORT]
REDIS_URL=redis://[USER]:[PASSWORD]@[HOST]:[PORT]

# أمان JWT
# استخدم أمر: openssl rand -base64 64
JWT_SECRET=[GENERATE-A-RANDOM-64-CHAR-STRING]

# Google Gemini API
GEMINI_API_KEY=[YOUR-GEMINI-API-KEY]

# مفتاح تشفير AES-256 (32 بايت Base64)
# استخدم أمر: openssl rand -base64 32
ENCRYPTION_KEY=[BASE64-32-BYTE-KEY]

# GCP Secret Manager (اختياري، للتوسع المستقبلي)
# GCP_PROJECT_ID=